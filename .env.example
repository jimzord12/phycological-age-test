# Reflective Maturity Profile — example environment configuration.
# Copy to `.env.local` and fill in real values. NEVER commit real secrets.
#
# The application MUST run with AI disabled. Leaving AI_PROVIDER unset (or
# without a key) keeps deterministic scoring fully functional (PRD §23).

# --- AI analysis (optional; deterministic scoring works without it) ---------
# Provider-agnostic switch. Supported adapters are added in the AI increment.
#   "none"      -> AI analysis disabled (default)
#   "anthropic" -> Anthropic Messages API or any Messages-compatible endpoint
#   "openai"    -> OpenAI-compatible Chat Completions / Responses API
AI_PROVIDER=none

# Anthropic-compatible providers (Anthropic itself, or Z.AI GLM Coding Plan,
# which exposes the Anthropic Messages protocol). The base URL is what makes
# this provider-agnostic — point it at whichever vendor you use.
#   Anthropic:        https://api.anthropic.com
#   Z.AI GLM Coding:  https://api.z.ai/api/anthropic
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# OpenAI-compatible providers (OpenAI, or Z.AI's OpenAI-compatible endpoint
# at https://api.z.ai/api/coding/paas/v4).
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Interactive timeout for a single analysis request, in milliseconds.
AI_ANALYSIS_TIMEOUT_MS=20000

# --- App ---------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
RATE_LIMIT_ENABLED=true
TELEMETRY_ENABLED=false
